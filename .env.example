# Xidig environment variables.
#
# Copy this file to `.env` and fill in the values. Every key here is validated
# at boot by apps/web/src/env.ts — a missing REQUIRED value makes the app refuse
# to start. Only Supabase (the 5 keys below) is hard-required; every other
# integration is OPTIONAL and degrades gracefully when unset — the app boots
# with that feature disabled (Sentry off, no rate limiting, email logged to
# console, moderation skipped, etc.). Fill them in before real members arrive.
#
# NODE_ENV is managed by the tooling; do not set it here.

# --- Supabase ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Browser-exposed mirror of the two values above — set these to the SAME
# URL/publishable-key. Next.js only inlines NEXT_PUBLIC_-prefixed vars into
# client bundles, so a separate literal var is required; there is no secret
# here, the publishable key is safe to expose (access is governed by Row
# Level Security).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- App ---
# Canonical origin of this deployment; auth links in self-sent emails are
# built from it (never from request headers), AND it is the apex-cutover
# switch: set EXACTLY https://xidig.net to un-gate front-door indexing +
# arm the app.xidig.net→apex 308. (optional) default: http://localhost:3000.
# WARNING: leave this line commented / the var UNSET to take the default — an
# empty value (APP_URL=) is not a URL and hard-fails boot validation.
# APP_URL=https://xidig.net

# --- Transactional email ---
# Auth emails (magic links, confirmations, resets) are sent by the app, not
# by Supabase SMTP — see docs/runbook.md "Supabase auth configuration".
# EMAIL_PROVIDER: auto | resend | console. (optional) default: auto —
#   resend in production, console (prints the link to the server log) in dev.
# EMAIL_FROM: (optional) default: Xidig <onboarding@resend.dev>
EMAIL_API_KEY=
EMAIL_PROVIDER=
EMAIL_FROM=
# Signing secret for the provider's delivery webhooks (Resend → Svix,
# "whsec_..."). Feeds the bounce/complaint suppression list. (optional)
# Empty = /api/webhooks/email returns 503.
EMAIL_WEBHOOK_SECRET=

# Front-door contact intake destination (optional). Where /contact messages
# are forwarded. Empty = the contact form is hidden and /api/contact 503s.
CONTACT_INBOX=

# --- Maps ---
MAPTILER_KEY=

# --- Meilisearch (search) ---
# For local dev, run `docker compose up -d` (see docker-compose.yml) to start
# a free, self-hosted Meilisearch instance instead of a paid cloud one.
# MEILISEARCH_API_KEY must equal MEILI_MASTER_KEY below in that case.
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# Consumed only by docker-compose.yml (local Meilisearch container), not by
# the app itself. Generate one with: openssl rand -base64 24
MEILI_MASTER_KEY=

# --- PostHog (analytics) ---
POSTHOG_KEY=
# (optional) default: https://us.i.posthog.com — leave the var UNSET to take
# the default. An empty value (POSTHOG_HOST=) is not a URL and hard-fails boot.
# POSTHOG_HOST=https://us.i.posthog.com

# --- Upstash (Redis / rate limiting) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Sentry (error monitoring) ---
SENTRY_DSN=
# Browser-exposed mirror of the value above (same DSN — not secret, just an
# event-ingestion address). Next.js only inlines NEXT_PUBLIC_-prefixed vars
# into client bundles, so a separate literal var is required.
NEXT_PUBLIC_SENTRY_DSN=

# Build-time only (source-map upload via withSentryConfig in next.config.ts).
# NOT validated by src/env.ts and NOT required to build — upload is skipped
# automatically when SENTRY_AUTH_TOKEN is unset (e.g. local dev).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- AI provider (moderation pre-scan, §15) ---
# For AI_MODERATION_PROVIDER=openai this is an OpenAI API key (the
# omni-moderation endpoint is free); for =anthropic it's an Anthropic key.
AI_API_KEY=
# openai  = OpenAI omni-moderation (free, multimodal text+image — recommended)
# anthropic = Claude Haiku · auto = anthropic in prod / console in dev
# console = log + skip (never blocks; content ships unscanned as 'skipped')
AI_MODERATION_PROVIDER=openai

# --- Scheduled jobs (/api/cron/*) ---
# Vercel Cron sends `Authorization: Bearer <CRON_SECRET>` automatically when
# this is set. Empty = cron routes disabled (503).
CRON_SECRET=

# --- Web Push / VAPID (Phase 3 PWA push, §22/§26) ---
# Generate a keypair once with:  npx web-push generate-vapid-keys
# All optional — leave blank and push is DISABLED (in-app notifications still
# work; the opt-in toggle explains the unconfigured state). See docs/runbook.md
# "Web push (Fariimo)". VAPID_SUBJECT is a contact URI: mailto:you@example.com
# or an https URL. NEXT_PUBLIC_VAPID_PUBLIC_KEY must equal VAPID_PUBLIC_KEY
# (the browser needs the public key to subscribe; only that value is exposed).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- Supabase CLI only (used by `pnpm db:gen-types`, not by the app) ---
# SUPABASE_PROJECT_ID=
