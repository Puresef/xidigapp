# Xidig environment variables.
#
# Copy this file to `.env` and fill in the values. Every key here is validated
# at boot by apps/web/src/env.ts — a missing required value makes the app refuse
# to start. Keys marked "(optional)" have a default and may be left blank.
#
# NODE_ENV is managed by the tooling; do not set it here.

# --- Supabase ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Browser-exposed mirror of the two values above — set these to the SAME
# URL/publishable-key. Next.js only inlines NEXT_PUBLIC_-prefixed vars into
# client bundles, so a separate literal var is required; there is no secret
# here, the publishable key is safe to expose (access is governed by Row
# Level Security).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- App ---
# Canonical origin of this deployment; auth links in self-sent emails are
# built from it (never from request headers). (optional) default:
# http://localhost:3000
APP_URL=

# --- Transactional email ---
# Auth emails (magic links, confirmations, resets) are sent by the app, not
# by Supabase SMTP — see docs/runbook.md "Supabase auth configuration".
# EMAIL_PROVIDER: auto | resend | console. (optional) default: auto —
#   resend in production, console (prints the link to the server log) in dev.
# EMAIL_FROM: (optional) default: Xidig <onboarding@resend.dev>
EMAIL_API_KEY=
EMAIL_PROVIDER=
EMAIL_FROM=

# --- Maps ---
MAPTILER_KEY=

# --- Meilisearch (search) ---
# For local dev, run `docker compose up -d` (see docker-compose.yml) to start
# a free, self-hosted Meilisearch instance instead of a paid cloud one.
# MEILISEARCH_API_KEY must equal MEILI_MASTER_KEY below in that case.
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# Consumed only by docker-compose.yml (local Meilisearch container), not by
# the app itself. Generate one with: openssl rand -base64 24
MEILI_MASTER_KEY=

# --- PostHog (analytics) ---
POSTHOG_KEY=
POSTHOG_HOST=            # (optional) default: https://us.i.posthog.com

# --- Upstash (Redis / rate limiting) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Sentry (error monitoring) ---
SENTRY_DSN=
# Browser-exposed mirror of the value above (same DSN — not secret, just an
# event-ingestion address). Next.js only inlines NEXT_PUBLIC_-prefixed vars
# into client bundles, so a separate literal var is required.
NEXT_PUBLIC_SENTRY_DSN=

# Build-time only (source-map upload via withSentryConfig in next.config.ts).
# NOT validated by src/env.ts and NOT required to build — upload is skipped
# automatically when SENTRY_AUTH_TOKEN is unset (e.g. local dev).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- AI provider ---
AI_API_KEY=

# --- Supabase CLI only (used by `pnpm db:gen-types`, not by the app) ---
# SUPABASE_PROJECT_ID=
